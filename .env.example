# Copy this file to .env and fill in your values.
# docker-compose automatically picks up .env from the project directory.

# ── IBKR connection ────────────────────────────────────────────────────────────
# IP of the machine running TWS / IB Gateway.
# Docker Desktop (Mac/Win): leave as host.docker.internal
# Linux: replace with your LAN IP, e.g. 192.168.1.100
IBKR_HOST=host.docker.internal

# 7497 = paper trading  |  7496 = live account
IBKR_PORT=7497

# Must be unique if you run multiple API clients simultaneously
IBKR_CLIENT_ID=10

# true = read-only (recommended — the dashboard never places orders)
IBKR_READONLY=true

# Seconds between reconnect attempts (exponential back-off applies on top)
IBKR_RECONNECT_DELAY=5

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASH_PORT=8050
REFRESH_INTERVAL=60

# ── AI analysis (optional) ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
